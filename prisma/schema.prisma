// Global Café Business School - Database Schema
// PostgreSQL via Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// AUTH & ADMIN
// ─────────────────────────────────────────────────────────────

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(EDITOR)
  avatar       String?
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admin_users")
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

// ─────────────────────────────────────────────────────────────
// SITE CONTENT — HERO SECTIONS
// ─────────────────────────────────────────────────────────────

model HeroSection {
  id              String      @id @default(cuid())
  page            String      @unique // e.g. "home", "about", "courses"
  badge           String?     // e.g. "☕ Professional Training Institute"
  headline        String      // Main heading
  headlineAccent  String?     // Highlighted part of heading
  subheadline     String?
  bodyText        String?     @db.Text
  ctaPrimary      String?     // Button label
  ctaPrimaryUrl   String?
  ctaSecondary    String?
  ctaSecondaryUrl String?
  // Images — separate for desktop and mobile for perfect responsive control
  desktopImageUrl String?
  desktopImageAlt String?
  mobileImageUrl  String?
  mobileImageAlt  String?
  // Video support
  videoUrl        String?
  videoPosterDesktop String?
  videoPosterMobile  String?
  overlayOpacity  Float       @default(0.5)
  overlayColor    String      @default("#000000")
  isActive        Boolean     @default(true)
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("hero_sections")
}

// ─────────────────────────────────────────────────────────────
// SITE CONTENT — BANNERS
// ─────────────────────────────────────────────────────────────

model Banner {
  id              String        @id @default(cuid())
  title           String
  subtitle        String?
  bodyText        String?       @db.Text
  ctaLabel        String?
  ctaUrl          String?
  // Desktop: full-width banner (e.g. 1440×400)
  desktopImageUrl String?
  desktopImageAlt String?
  desktopWidth    Int?
  desktopHeight   Int?
  // Mobile: portrait-friendly crop (e.g. 768×300)
  mobileImageUrl  String?
  mobileImageAlt  String?
  mobileWidth     Int?
  mobileHeight    Int?
  placement       BannerPlacement @default(HOME_TOP)
  bgColor         String?
  textColor       String?
  isActive        Boolean       @default(true)
  startsAt        DateTime?
  endsAt          DateTime?
  sortOrder       Int           @default(0)
  clickCount      Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("banners")
}

enum BannerPlacement {
  HOME_TOP
  HOME_MID
  HOME_BOTTOM
  COURSES_TOP
  SIDEBAR
  POPUP
  ANNOUNCEMENT_BAR
}

// ─────────────────────────────────────────────────────────────
// COURSES
// ─────────────────────────────────────────────────────────────

model CourseCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  iconUrl     String?
  sortOrder   Int      @default(0)
  courses     Course[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("course_categories")
}

model Course {
  id                String         @id @default(cuid())
  categoryId        String
  category          CourseCategory @relation(fields: [categoryId], references: [id])
  title             String
  slug              String         @unique
  tagline           String?
  description       String         @db.Text
  duration          String         // e.g. "6 months", "12 weeks"
  durationWeeks     Int?
  level             CourseLevel    @default(DIPLOMA)
  language          String         @default("English")
  // Fees
  localFee          Decimal?       @db.Decimal(10, 2)
  intlFee           Decimal?       @db.Decimal(10, 2)
  currency          String         @default("SGD")
  // Images
  thumbnailDesktop  String?        // 800×533 landscape
  thumbnailMobile   String?        // 400×533 portrait
  bannerDesktop     String?        // 1440×480
  bannerMobile      String?        // 768×400
  // Structured content (JSON)
  curriculum        Json?          // Array of modules with topics
  outcomes          Json?          // Array of learning outcomes
  careerPaths       Json?          // Array of career options
  entryRequirements Json?
  highlights        Json?          // Key features array
  isFeatured        Boolean        @default(false)
  isActive          Boolean        @default(true)
  sortOrder         Int            @default(0)
  metaTitle         String?
  metaDescription   String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("courses")
}

enum CourseLevel {
  CERTIFICATE
  DIPLOMA
  ADVANCED_DIPLOMA
  HIGHER_DIPLOMA
  POSTGRADUATE_DIPLOMA
}

// ─────────────────────────────────────────────────────────────
// CANDIDATES / ENQUIRIES — CTA Form submissions
// ─────────────────────────────────────────────────────────────

model Candidate {
  id              String          @id @default(cuid())
  // Personal
  firstName       String
  lastName        String
  email           String
  phone           String?
  countryCode     String?         @default("+65")
  dateOfBirth     DateTime?
  nationality     String?
  // Interest
  courseInterest  String?         // Which course they're interested in
  courseLevel     String?
  intakePreference String?        // e.g. "Jan 2025", "Flexible"
  studentType     StudentType     @default(LOCAL)
  // Enquiry
  message         String?         @db.Text
  source          String?         // utm_source / how they heard
  referralCode    String?
  // Status workflow
  status          CandidateStatus @default(NEW)
  notes           String?         @db.Text // Admin internal notes
  followUpAt      DateTime?
  // Consent
  marketingConsent Boolean        @default(false)
  privacyConsent   Boolean        @default(true)
  // Meta
  ipAddress       String?
  userAgent       String?
  pageUrl         String?         // Which page they submitted from
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  activities      CandidateActivity[]

  @@map("candidates")
}

enum StudentType {
  LOCAL
  INTERNATIONAL
  ONLINE
}

enum CandidateStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  ENROLLED
  REJECTED
  WITHDRAWN
}

model CandidateActivity {
  id          String    @id @default(cuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  action      String    // e.g. "Email sent", "Called", "Status changed"
  note        String?
  performedBy String?   // Admin user name
  createdAt   DateTime  @default(now())

  @@map("candidate_activities")
}

// ─────────────────────────────────────────────────────────────
// TESTIMONIALS
// ─────────────────────────────────────────────────────────────

model Testimonial {
  id          String   @id @default(cuid())
  name        String
  role        String?  // e.g. "Café Owner, Singapore"
  courseTitle String?
  rating      Int      @default(5) // 1-5
  quote       String   @db.Text
  // Portrait image — separate mobile/desktop crops
  photoDesktop String? // 200×200 square
  photoMobile  String? // 160×160 square
  videoUrl    String?
  isFeatured  Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("testimonials")
}

// ─────────────────────────────────────────────────────────────
// TEAM / FACULTY
// ─────────────────────────────────────────────────────────────

model TeamMember {
  id           String   @id @default(cuid())
  name         String
  title        String   // Job title
  department   String?  // e.g. "Faculty", "Administration"
  bio          String?  @db.Text
  qualifications Json?  // Array of qualification strings
  specializations Json? // Array of specialization strings
  // Images
  photoDesktop String?  // 400×500 portrait
  photoMobile  String?  // 300×380 portrait
  linkedinUrl  String?
  email        String?
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("team_members")
}

// ─────────────────────────────────────────────────────────────
// GALLERY
// ─────────────────────────────────────────────────────────────

model GalleryImage {
  id          String      @id @default(cuid())
  title       String?
  altText     String?
  caption     String?
  category    GalleryCategory @default(CAMPUS)
  // Separate desktop and mobile srcsets for art direction
  desktopUrl  String      // 1200×800
  mobileUrl   String      // 600×400 or portrait 400×600
  thumbUrl    String?     // 400×300 thumbnail
  width       Int?
  height      Int?
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("gallery_images")
}

enum GalleryCategory {
  CAMPUS
  TRAINING
  EVENTS
  STUDENTS
  COFFEE_LAB
  BARISTA_COMP
}

// ─────────────────────────────────────────────────────────────
// SITE SETTINGS — Key-value store for dynamic config
// ─────────────────────────────────────────────────────────────

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("text") // text, json, boolean, image
  label     String?
  group     String?  // e.g. "contact", "social", "seo"
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ─────────────────────────────────────────────────────────────
// ANNOUNCEMENTS — Top bar / notification strip
// ─────────────────────────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  message   String
  ctaLabel  String?
  ctaUrl    String?
  bgColor   String   @default("#C8860A")
  textColor String   @default("#FFFFFF")
  isActive  Boolean  @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

// ─────────────────────────────────────────────────────────────
// STATS — Dynamic counters shown on site
// ─────────────────────────────────────────────────────────────

model Stat {
  id        String   @id @default(cuid())
  label     String
  value     String   // e.g. "500+", "15", "98%"
  icon      String?  // Icon name or emoji
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("stats")
}

// ─────────────────────────────────────────────────────────────
// PARTNERS / ACCREDITATIONS — Logos displayed on site
// ─────────────────────────────────────────────────────────────

model Partner {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String
  logoUrlDark String?  // Dark mode variant
  websiteUrl  String?
  type        PartnerType @default(INDUSTRY)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("partners")
}

enum PartnerType {
  ACCREDITATION
  INDUSTRY
  PLACEMENT
  MEDIA
}

// ─────────────────────────────────────────────────────────────
// ABOUT PAGE — Dynamic editable content
// ─────────────────────────────────────────────────────────────

model AboutPage {
  id              String   @id @default(cuid())
  // Mission Section
  missionBadge    String?  @default("Our Mission") @map("mission_badge")
  missionTitle    String?  @default("Transforming Coffee Passion") @map("mission_title")
  missionAccent   String?  @default("into Professional Careers") @map("mission_accent")
  missionBody     String?  @db.Text @map("mission_body")
  missionImageUrl String? @map("mission_image_url")
  missionImageAlt String?  @default("GCBS Campus") @map("mission_image_alt")
  // Highlights (bullets)
  highlights      Json?    // Array of highlight strings
  // Values
  values          Json?    // Array of {icon, title, description}
  // CTA Section
  ctaHeading      String?  @default("Ready to Join Our Community?") @map("cta_heading")
  ctaSubheading   String?  @default("Take the first step towards your café career.") @map("cta_subheading")
  ctaLabel        String?  @default("Apply Now") @map("cta_label")
  ctaUrl          String?  @default("/#apply") @map("cta_url")
  isActive        Boolean  @default(true) @map("is_active")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("about_pages")
}

// ─────────────────────────────────────────────────────────────
// ADMISSION PAGE — Dynamic editable content
// ─────────────────────────────────────────────────────────────

model AdmissionPage {
  id              String   @id @default(cuid())
  // Hero Section managed via HeroSection with page='admissions'
  // Requirements Section
  reqTitle        String?  @default("Entry Requirements") @map("req_title")
  reqSubtitle     String?  @db.Text @map("req_subtitle")
  requirements    Json?    // Array of requirement objects
  // Process Section
  processTitle    String?  @default("Application Process") @map("process_title")
  processSteps    Json? @map("process_steps")   // Array of step objects with title, description
  // FAQ Section
  faqTitle        String?  @default("Frequently Asked Questions") @map("faq_title")
  faqs            Json?    // Array of {question, answer}
  // Documents Section
  documents       Json?    // Array of required documents
  // Contact Info
  contactEmail    String? @map("contact_email")
  contactPhone    String? @map("contact_phone")
  contactHeading  String?  @default("Questions? Get in Touch") @map("contact_heading")
  contactBody     String?  @db.Text @map("contact_body")
  // CTA
  ctaLabel        String?  @default("Start Your Application") @map("cta_label")
  ctaUrl          String? @map("cta_url")
  isActive        Boolean  @default(true) @map("is_active")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("admission_pages")
}
